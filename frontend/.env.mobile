# 모바일(Capacitor) 빌드 전용 — `vite build --mode mobile` 에서만 로드.
# 웹 prod 빌드(`npm run build`)는 이 파일을 읽지 않으므로 동일-origin 상대경로 유지.
#
# 네이티브 WebView 는 capacitor://localhost 에서 자산을 로드하므로
# 상대경로 /api/* 가 백엔드에 닿지 않는다. 반드시 절대 URL 주입.
VITE_API_BASE_URL=https://www.palette.ai.kr

# Toss publishable(client) key — test (정식 출시 시 live_ck_ 로 교체).
# secret key 아님(프론트 노출 안전). 백엔드 TOSS_SECRET_KEY 와 별개.
VITE_TOSS_CLIENT_KEY=test_ck_yL0qZ4G1VOKE6oYpgEJBVoWb2MQY
