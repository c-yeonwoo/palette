# ============================================================
# Palette — Environment Variables Reference
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Authentication ────────────────────────────────────────

# JWT signing secret (minimum 256 bits).
# Generate: openssl rand -base64 64
JWT_SECRET=

# Kakao OAuth2 (REST API key + client secret)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google OAuth2 (optional — Phase 2)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Naver OAuth2 (optional — Phase 2)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# Frontend redirect URI after OAuth callback
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# ── Database ──────────────────────────────────────────────

# Local dev: H2 자동 (설정 불필요)
# Dev/Prod 서버: MySQL (docker-compose.server.yml)
MYSQL_HOST=db               # docker compose 내부 서비스명
MYSQL_PORT=3306
MYSQL_DATABASE=palette
MYSQL_USERNAME=palette
MYSQL_PASSWORD=              # 안전한 비밀번호 설정
MYSQL_ROOT_PASSWORD=         # root 비밀번호 (docker mysql 컨테이너용)

# ── Spring Profile ────────────────────────────────────────
# dev (EC2 dev서버) | prod (EC2 prod서버) | local (로컬 H2)
SPRING_PROFILES_ACTIVE=dev

# ── 베타 게이트 ────────────────────────────────────────────
# 값이 있으면 회원가입 시 베타 코드 필수, 빈 값이면 비활성
# 정식 출시 시 빈 값으로 변경하면 누구나 가입 가능
BETA_CODE=palette-beta-2026

# ── Docker Image Tag ──────────────────────────────────────
# GitHub Actions가 자동 설정. 수동 배포 시 직접 지정
IMAGE_TAG=dev

# ── Redis (Refresh Tokens + Phone Verification) ───────────

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AWS S3 (Profile photos / videos) ─────────────────────

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=palette-data-v1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── NCP SENS (SMS / Phone Verification) ──────────────────

NCP_SENS_ACCESS_KEY=
NCP_SENS_SECRET_KEY=
NCP_SENS_SERVICE_ID=
NCP_SENS_FROM_NUMBER=01000000000

# ── OpenAI (AI Profile Generation) ───────────────────────

OPENAI_API_KEY=

# ── NICE 본인인증 API v2.0 ────────────────────────────────
# 발급: https://developer.niceid.co.kr/
# 미설정 시 DEV bypass 모드 (NICE 팝업 없이 수동 입력으로 대체)
NICE_CLIENT_ID=
NICE_CLIENT_SECRET=
NICE_PRODUCT_ID=2101979031

# 앱 외부 URL (NICE 콜백 returnurl — prod에서 필수)
APP_BASE_URL=https://api.palette.kr

# ── Toss Payments (Card unlock, Profile view fee) ─────────

TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ── Firebase FCM (Push Notifications) ────────────────────

# Option 1: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Option 2: JSON content as env var (for containerized envs)
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=

# ── CORS (Production) ─────────────────────────────────────

# Comma-separated list of allowed origins
# CORS_ALLOWED_ORIGINS=https://palette.kr,https://www.palette.kr

# ── Spring Profile ────────────────────────────────────────

# local | dev | prod
SPRING_PROFILES_ACTIVE=local
