# ============================================================
# Palette — Environment Variables Reference
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Authentication ────────────────────────────────────────

# JWT signing secret (minimum 256 bits).
# Generate: openssl rand -base64 64
JWT_SECRET=

# Kakao OAuth2 (REST API key + client secret)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Google OAuth2 (optional — Phase 2)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Naver OAuth2 (optional — Phase 2)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# Frontend redirect URI after OAuth callback
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# ── Database ──────────────────────────────────────────────

# Local dev: H2 자동 (설정 불필요)
# Dev/Prod 서버: MySQL (docker-compose.server.yml)
MYSQL_HOST=db               # docker compose 내부 서비스명
MYSQL_PORT=3306
MYSQL_DATABASE=palette
MYSQL_USERNAME=palette
MYSQL_PASSWORD=              # 안전한 비밀번호 설정
MYSQL_ROOT_PASSWORD=         # root 비밀번호 (docker mysql 컨테이너용)

# ── Spring Profile ────────────────────────────────────────
# dev (EC2 dev서버) | prod (EC2 prod서버) | local (로컬 H2)
SPRING_PROFILES_ACTIVE=dev

# ── 베타 게이트 ────────────────────────────────────────────
# 값이 있으면 회원가입 시 베타 코드 필수, 빈 값이면 비활성
# 정식 출시 시 빈 값으로 변경하면 누구나 가입 가능
# (실제 코드는 커밋 금지 — prod .env 에만 둘 것)
BETA_CODE=

# 베타 과금 정책 (BetaPolicy) — true 면 물감 소비(프로필 열람·소개 요청) 전면 무료, 결제/충전 유도 숨김.
# 정식 출시 시 false 로 변경하면 PointPrice 단가대로 정상 과금 (친친 20 / 한 다리 더 30 물감).
BETA_FREE_UNLOCK=true

# ── Docker Image Tag ──────────────────────────────────────
# GitHub Actions CD 가 매 배포마다 .env 의 IMAGE_TAG 를 갱신함.
# 수동으로 첫 시작 시에만 지정 (그 이후엔 CD 가 알아서 관리).
IMAGE_TAG=latest

# ── Redis (Refresh Tokens + Phone Verification) ───────────

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AWS S3 (Profile photos / videos) ─────────────────────

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET_NAME=palette-data-v1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── NCP SENS (SMS / Phone Verification) ──────────────────
# 베타 단계: SMS_PROVIDER=mock + PHONE_VERIFICATION_BYPASS=true (자동 통과)
# 정식 출시: SMS_PROVIDER=ncp + PHONE_VERIFICATION_BYPASS=false + 아래 키 채우기

SMS_PROVIDER=mock                     # mock | ncp
# 정식 출시: SMS_PROVIDER=ncp + PHONE_VERIFICATION_BYPASS=false + NCP 키 채우기
PHONE_VERIFICATION_BYPASS=false        # true 시 SMS 안 보내고 "000000" 자동 통과 (베타 전용)

NCP_SENS_ACCESS_KEY=
NCP_SENS_SECRET_KEY=
NCP_SENS_SERVICE_ID=
NCP_SENS_FROM_NUMBER=01000000000

# ── OpenAI (AI Profile Generation) ───────────────────────

OPENAI_API_KEY=

# ── NICE 본인인증 API v2.0 ────────────────────────────────
# 발급: https://developer.niceid.co.kr/
# 미설정 시 DEV bypass 모드 (NICE 팝업 없이 수동 입력으로 대체)
NICE_CLIENT_ID=
NICE_CLIENT_SECRET=
NICE_PRODUCT_ID=2101979031

# 앱 외부 URL (NICE 콜백 returnurl — prod에서 필수)
APP_BASE_URL=https://api.palette.kr

# ── Toss Payments (PA-002 — 티켓 충전·구독 결제) ─────────
# PAYMENT_GATEWAY: mock (베타 기본, 외부 결제 미사용) | toss (test/live 키 필요)
PAYMENT_GATEWAY=mock

# 가맹 신청 후 Toss 개발자 콘솔(https://developers.tosspayments.com)에서 발급
# - CLIENT key: 프론트 SDK 노출용 (test_ck_... / live_ck_...)
# - SECRET key: 백엔드 confirm API 호출용 — 절대 프론트 노출 금지 (test_sk_... / live_sk_...)
# 실제 키는 .env(gitignore) / prod 시크릿에만. example 에는 커밋 금지.
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Apple IAP restore (PA-003) — 미설정 시 베타 stub 모드
APPLE_IAP_SHARED_SECRET=

# ── Firebase FCM (Push Notifications) ────────────────────

# Option 1: path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Option 2: JSON content as env var (for containerized envs)
FIREBASE_SERVICE_ACCOUNT_KEY_JSON=

# ── CORS (Production) ─────────────────────────────────────

# Comma-separated list of allowed origins
# CORS_ALLOWED_ORIGINS=https://palette.kr,https://www.palette.kr

# ── Spring Profile ────────────────────────────────────────

# local | dev | prod
SPRING_PROFILES_ACTIVE=local
